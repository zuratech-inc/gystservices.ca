---
layout: layouts/page.njk
title: Community Events
description: "Join GYST Counselling for workshops, sharing circles, and educational gatherings. Everyone is welcome — registration is open."
permalink: /events/
---

{# ── Page hero ── #}
<section class="page-hero page-hero--events">
  <div class="page-hero-inner">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Events</span>
    </nav>
    <h1>Community Events</h1>
    <p>Join us for workshops, sharing circles, and educational gatherings. Everyone is welcome — registration is open.</p>
  </div>
</section>

{# ── Filter bar (visual only) ── #}
<div class="filters-bar" aria-label="Filter events by type">
  <div class="filters-inner">
    <span class="filter-label">Filter:</span>
    <a href="/events/" class="filter-btn active">All Events</a>
    <a href="/events/" class="filter-btn">Workshops</a>
    <a href="/events/" class="filter-btn">Circles</a>
    <a href="/events/" class="filter-btn">Seminars</a>
    <a href="/events/" class="filter-btn">Talks</a>
    <a href="/events/" class="filter-btn">Retreats</a>
  </div>
</div>

{# ── Events listing ── #}
<section class="events-section" aria-label="Event listing">
  <div class="events-inner">
    {% set events = collections.event | reverse %}
    {% if events.length %}
      <div class="events-grid">
        {% for event in events %}
          {% set tagClass = 'tag-' + (event.data.eventType | default('workshop') | lower | replace(' ', '-')) %}
          <div class="event-card">
            <div class="event-banner">
              {% if event.data.eventDate %}
                <div class="event-date-badge">
                  <div class="month">{{ event.data.eventDate | date('LLLL d, yyyy') | truncate(3, false, '') }}</div>
                  <div class="day">{{ event.data.eventDate | date('yyyy-MM-dd') | replace(r/^\d{4}-\d{2}-/, '') | int }}</div>
                </div>
              {% endif %}
              <div class="event-banner-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>
              </div>
            </div>
            <div class="event-body">
              {% if event.data.eventType %}
                <span class="event-tag {{ tagClass }}">{{ event.data.eventType }}</span>
              {% endif %}
              <h3><a href="{{ event.url }}" class="event-card-link">{{ event.data.title }}</a></h3>
              <p>{{ event.data.description }}</p>
              <div class="event-meta">
                {% if event.data.eventTime %}
                  <span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                    {{ event.data.eventTime }}
                  </span>
                {% endif %}
                {% if event.data.location %}
                  <span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                    {{ event.data.location }}
                  </span>
                {% endif %}
              </div>
              <div class="event-footer">
                <a href="{{ event.url }}" class="btn-register">
                  Register Now
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"/></svg>
                </a>
                {% if event.data.spots %}
                  <span class="event-spots{% if event.data.spots <= 10 %} few{% endif %}">{{ event.data.spots }} spots left</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="listing-empty">No upcoming events. Check back soon!</p>
    {% endif %}
  </div>
</section>
