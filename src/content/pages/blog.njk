---
layout: layouts/page.njk
title: Blog
description: "Insights and reflections on wellness, cultural identity, personal growth, and the journey of becoming — from Valerie M. Sipos, M.C., CCC."
permalink: /blog/
---

{# ── Page hero ── #}
<section class="page-hero page-hero--blog">
  <div class="page-hero-inner">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Blog</span>
    </nav>
    <h1>Insights &amp; Reflections</h1>
    <p>Thoughts on wellness, cultural identity, growth, and the journey of becoming.</p>
  </div>
</section>

{# ── Filter bar (visual only — JS-free progressive enhancement) ── #}
<div class="filters-bar" aria-label="Filter posts by topic">
  <div class="filters-inner">
    <span class="filter-label">Topics:</span>
    <a href="/blog/" class="filter-btn active">All</a>
    <a href="/blog/" class="filter-btn">Culture &amp; Healing</a>
    <a href="/blog/" class="filter-btn">Personal Growth</a>
    <a href="/blog/" class="filter-btn">Family Systems</a>
    <a href="/blog/" class="filter-btn">Wellness</a>
    <a href="/blog/" class="filter-btn">Community</a>
  </div>
</div>

{# ── Blog post listing ── #}
<section class="blog-section" aria-label="Blog posts">
  <div class="blog-inner">
    {% set posts = collections.post | reverse %}
    {% if posts.length %}
      {# Featured post — first item gets the wide 2-column layout #}
      {% set featuredPost = posts[0] %}
      <article class="featured-post">
        <div class="featured-img" aria-hidden="true">
          <span class="featured-label">&#10022; Featured</span>
          <div class="fi">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          </div>
        </div>
        <div class="featured-body">
          <div class="blog-meta">
            {% if featuredPost.data.category %}
              <span class="blog-category cat-{{ featuredPost.data.category | lower | replace(' ', '-') | replace('&', '') | replace('  ', '-') }}">{{ featuredPost.data.category }}</span>
            {% endif %}
            <span class="blog-date">
              <time datetime="{{ featuredPost.date | date('yyyy-MM-dd') }}">{{ featuredPost.date | date('LLLL d, yyyy') }}</time>
              {% if featuredPost.data.readTime %} · {{ featuredPost.data.readTime }}{% endif %}
            </span>
          </div>
          <h2><a href="{{ featuredPost.url }}">{{ featuredPost.data.title }}</a></h2>
          <p>{{ featuredPost.data.description }}</p>
          <a href="{{ featuredPost.url }}" class="blog-read-link">
            Read full article
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"/></svg>
          </a>
          <div class="blog-author">
            <div class="blog-avatar" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0"/></svg>
            </div>
            <div>
              <div class="blog-aname">{{ site.practitioner.name }}</div>
              <div class="blog-arole">{{ site.practitioner.credentials }} — Founder, {{ site.name }}</div>
            </div>
          </div>
        </div>
      </article>

      {# Remaining posts as cards #}
      {% if posts.length > 1 %}
        <div class="blog-grid">
          {% for post in posts %}
            {% if loop.index > 1 %}
              <article class="blog-card">
                <div class="blog-card-img" aria-hidden="true">
                  <div class="ci">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
                  </div>
                </div>
                <div class="blog-card-body">
                  <div class="blog-meta">
                    {% if post.data.category %}
                      <span class="blog-category cat-{{ post.data.category | lower | replace(' ', '-') | replace('&', '') | replace('  ', '-') }}">{{ post.data.category }}</span>
                    {% endif %}
                    <span class="blog-date">
                      <time datetime="{{ post.date | date('yyyy-MM-dd') }}">{{ post.date | date('LLLL d, yyyy') }}</time>
                      {% if post.data.readTime %} · {{ post.data.readTime }}{% endif %}
                    </span>
                  </div>
                  <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                  <p>{{ post.data.description }}</p>
                  {% if post.data.tags %}
                    <div class="post-tags">
                      {% for tag in post.data.tags %}
                        {% if tag != 'post' %}
                          <span class="post-tag">{{ tag }}</span>
                        {% endif %}
                      {% endfor %}
                    </div>
                  {% endif %}
                  <div class="blog-card-footer">
                    <div class="blog-author">
                      <div class="blog-avatar" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0"/></svg>
                      </div>
                      <div>
                        <div class="blog-aname">{{ site.practitioner.name }}</div>
                        <div class="blog-arole">{{ site.practitioner.credentials }}</div>
                      </div>
                    </div>
                    <a href="{{ post.url }}" class="blog-read-link">
                      Read
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"/></svg>
                    </a>
                  </div>
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

    {% else %}
      <p class="listing-empty">No posts yet. Check back soon!</p>
    {% endif %}
  </div>
</section>
