{#
  layouts/event.njk — Event detail layout
  Extends base.njk via Nunjucks inheritance.
  Shows banner, breadcrumb, info grid, registration bar,
  and the full event description (prose content).
#}
{% set navSolid = true %}
{% set ogType = "event" %}
{% extends "layouts/base.njk" %}

{% block body_content %}

  {# ── Page top: breadcrumb + gradient banner ── #}
  <div class="page-top">
    <div class="page-top-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/events/">Events</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{{ title }}</span>
      </nav>
      <div class="ev-banner" aria-hidden="true">
        <div class="ev-banner-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>
        </div>
      </div>
    </div>
  </div>

  {# ── Event content ── #}
  <div class="ev-wrap">

    {# Category tag #}
    {% if eventType %}
      <span class="ev-category tag-{{ eventType | lower }}">{{ eventType }}</span>
    {% endif %}

    {# Title #}
    <h1 class="ev-title">{{ title }}</h1>

    {# Date line #}
    {% if eventDate %}
      <p class="ev-date-line">
        <time datetime="{{ eventDate | date('yyyy-MM-dd') }}">{{ eventDate | date('LLLL d, yyyy') }}</time>
        {% if eventTime %} &mdash; {{ eventTime }}{% endif %}
      </p>
    {% endif %}

    {# Short description #}
    {% if description %}
      <p class="ev-short-desc">{{ description }}</p>
    {% endif %}

    {# Info grid: Time, Location, Spots, Price #}
    <div class="info-grid">
      <div class="info-card">
        <div class="info-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>
        <div class="info-label">Time</div>
        <div class="info-value">{{ eventTime | default('See details') }}</div>
      </div>
      <div class="info-card">
        <div class="info-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
        </div>
        <div class="info-label">Location</div>
        <div class="info-value">{{ location | default('HOA Community Room') }}</div>
      </div>
      <div class="info-card">
        <div class="info-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772"/></svg>
        </div>
        <div class="info-label">Spots Left</div>
        <div class="info-value">{{ spots | default('Open') }}{% if spots %} available{% endif %}</div>
      </div>
      <div class="info-card">
        <div class="info-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>
        </div>
        <div class="info-label">Cost</div>
        <div class="info-value">{{ price | default('Free') }}</div>
      </div>
    </div>

    {# Registration bar #}
    <div class="register-bar">
      <div class="reg-spots">
        <span class="reg-dot{% if spots and spots <= 10 %} few{% endif %}" aria-hidden="true"></span>
        {{ spots | default('Open') }}{% if spots %} spots remaining{% else %} registration{% endif %}
      </div>
      <span class="reg-price">{{ price | default('Free') }}</span>
      <a href="/#contact" class="btn-register">
        Register Now
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"/></svg>
      </a>
    </div>

    {# Divider + long description (prose content from Markdown) #}
    <div class="section-divider" aria-hidden="true"></div>
    <p class="section-label">Event Details</p>
    <div class="ev-long-desc">
      {{ content | safe }}
    </div>

    {# Back link #}
    <div class="back-row">
      <a href="/events/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 15.75 3 12m0 0 3.75-3.75M3 12h18"/></svg>
        Back to all events
      </a>
    </div>

  </div>

{% endblock %}
